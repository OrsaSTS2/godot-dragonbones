{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build addon (release)",
            "type": "process",
            "command": "python",
            "args": ["-m", "SCons", "target=template_release"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build addon (debug)",
            "type": "process",
            "command": "python",
            "args": ["-m", "SCons", "target=template_debug", "debug_symbols=yes"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build addon (debug + release)",
            "dependsOrder": "sequence",
            "dependsOn": ["Build addon (debug)", "Build addon (release)"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Generate compile_commands.json",
            "type": "process",
            "command": "python",
            "args": ["-m", "SCons", "compiledb=yes", "compile_commands.json"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Clean build",
            "type": "process",
            "command": "python",
            "args": ["-m", "SCons", "-c"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        }
    ]
}
